<resources>

    <!-- Launch Theme (Splash Screen) -->
    <style name="LaunchTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_screen</item>
    </style>

    <!-- Main App Theme -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Customize your theme here -->
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        
        <!-- Spinner/Dropdown Styles -->
        <item name="android:spinnerItemStyle">@style/SpinnerItem</item>
        <item name="android:spinnerDropDownItemStyle">@style/SpinnerDropDownItem</item>
    </style>

    <!-- Spinner Item Style (Selected Item) -->
    <style name="SpinnerItem" parent="Theme.AppCompat.Light">
        <item name="android:textColor">#2C3E50</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Spinner Dropdown Item Style (Dropdown List Items) -->
    <style name="SpinnerDropDownItem" parent="Theme.AppCompat.Light">
        <item name="android:textColor">#2C3E50</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:background">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">12dp</item>
    </style>

</resources>